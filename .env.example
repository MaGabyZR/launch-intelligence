# ─── Database — Neon Postgres (free tier, no credit card) ────────────────────
# Get both strings at: https://neon.tech → your project → Connection Details
#
# DATABASE_URL  → pooled connection (has -pooler. in the hostname)
#                 Used by Prisma at runtime inside Vercel serverless functions
# DIRECT_URL    → direct/unpooled connection (no -pooler. in hostname)
#                 Used by `prisma db push` and `prisma migrate dev`
#
# Neon provides these as "Connection string" and "Direct connection string"
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ─── External Data APIs ───────────────────────────────────────────────────────
# X (Twitter) API v2 — Bearer token. Free Basic tier: 500K tweets/month
# https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=

# Crunchbase Basic API — Free tier available
# https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=

# Apollo.io — Free tier: 50 credits/month (enough to start)
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Hunter.io — Free tier: 25 searches/month
# https://hunter.io/api
HUNTER_API_KEY=

# Anthropic Claude API — Pay-per-use (DM drafts only, very low cost)
# ~$0.003 per DM draft with claude-haiku. 100 drafts = $0.30
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Vercel Cron security ─────────────────────────────────────────────────────
# Any random string — used to secure cron endpoints
CRON_SECRET=your-random-secret-here

# ─── App ──────────────────────────────────────────────────────────────────────
# Set automatically by Vercel. Override locally if needed.
VITE_APP_URL=http://localhost:5173
